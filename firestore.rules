rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection – any signed-in user can read their own profile;
    // creation/update is also allowed so auth-context can bootstrap a profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All other collections (employees, attendance, leaveRequests, payroll, payslips, etc.)
    // are readable/writable by any authenticated user.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}